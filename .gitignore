# Plain material database stays local only — distribute the encrypted copy.
data/material_db.json
# Backups created during edits
data/material_db.json.bak
data/material_db.json.*bak*
data/material_db.json.preseed
data/material_db.json.preen
data/material_db.json.skillbak
# Legacy single-file format from v1 — release model is now archive/-based
data/material_db.json.enc

# User-specific keystore — never commit
keys.txt
.mds_viewer_keys
# Maintainer's master keystore (different filename so it can't collide)
keys.master.txt

# Skill workspace artifacts (cached TDS, agent extractions, verify reports)
_tds_workspace/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Log files
log/
_build.log

# Build output
build/
dist/
*.spec
*.exe
# Nuitka intermediate folders
main.build/
main.dist/
main.onefile-build/
.venv/

# Claude per-machine settings (never commit)
.claude/settings.local.json

# Stale v1.0 manifest — kept locally but not committed (regenerate on demand)
CHECKSUMS.txt

# One-off maintainer scripts (BLT vendor scrape etc.) — useful locally, not for the repo
_blt_*.py
_audit_*.py
_velo3d_*.py
_fix_*.py
_blt_tds_images/

# Vendor-supplied TDS PDFs that aren't publicly linked (e.g. Velo3D).
# These are the source-of-truth for extraction but MUST NOT be uploaded
# — they are licensed material from the vendor.
input/
*.pdf

# Local report sanity-check output (G audit artefacts)
_test_reports/

# Daily worklogs / personal memos — local only
WORKLOG_*.md
worklogs/

# Skill-creator scratch
skills/refresh-tds-catalog/__pycache__/

# ======================================================================
# Repo is distribution-only — encrypted .enc files only.
# Everything below stays local on the maintainer's machine and is NOT
# uploaded. Source code, build scripts, the refresh skill, contribution
# tooling, and maintainer-side docs are all excluded.
# Re-enable selectively if collaboration on source ever moves to this
# repo, or move source to a private companion repo.
# ======================================================================

# Source code (all .py)
*.py

# Build scripts + helpers
*.bat
*.cmd

# Maintainer-side docs (README.md and LICENSE_NOTICE.txt stay tracked)
CONTRIBUTING.md
DISTRIBUTION.md
requirements.txt

# Refresh-TDS skill (maintainer-only tooling)
.claude/

# Contribution CLI infra (replaced in-app by Submit TDS data dialog)
contributions/

# Worklogs / personal notes
WORKLOG_*.md
worklogs/
